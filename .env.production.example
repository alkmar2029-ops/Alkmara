# ============================================================
# Vercel deployment — TEACHER PORTAL ONLY
# ============================================================
# Copy these into Vercel → Project → Settings → Environment Variables.
# Do NOT commit real values. The values shown here are placeholders.

# --- Supabase (same project as local admin) ---
NEXT_PUBLIC_SUPABASE_URL=https://yufpttbzfucrznbftnnv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Lock the deployment to teacher portal only ---
# Hides /dashboard/* and admin-only API endpoints. Teachers see /teacher only.
NEXT_PUBLIC_TEACHER_ONLY=true

# --- Public URL of the deployed teacher portal ---
# Used by the LOCAL admin instance when sending WhatsApp credentials so the
# link the teacher receives points to Vercel, not localhost.
# (Optional on Vercel itself — only required on the local admin's .env.local.)
NEXT_PUBLIC_PORTAL_URL=https://your-teacher-portal.vercel.app

# --- ZKTeco device defaults (not used on Vercel — kept for type compat) ---
ZK_DEFAULT_PORT=4370
ZK_DEFAULT_CMD_PORT=5200
ZK_CONNECTION_TIMEOUT=5000
